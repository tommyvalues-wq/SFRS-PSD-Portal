<%- include('layout-top') %>

<section class="panel">
  <div class="page-head">
    <h1>Firefighters</h1>
    <a class="primary-btn" href="/firefighters/new">Add Firefighter</a>
  </div>

  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Rank</th>
        <th>Station</th>
        <th>Command Level</th>
        <th>Status</th>
        <th>Roblox ID</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% firefighters.forEach(f => { %>
        <tr>
          <td><%= f.name %></td>
          <td><%= f.rank %></td>
          <td><%= f.station || '-' %></td>
          <td><span class="badge"><%= f.command_level || 'No Command' %></span></td>
          <td><%= f.status %></td>
          <td><%= f.roblox_id || '-' %></td>
          <td>
            <a href="/firefighters/<%= f.id %>/edit">Edit</a>
            <form method="post" action="/firefighters/<%= f.id %>/delete" style="display:inline">
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('layout-bottom') %>
