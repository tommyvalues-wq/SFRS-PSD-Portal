<%- include('layout-top') %>

<section class="panel">

  <div class="page-head" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:15px;">

    <h1>Firefighters</h1>

    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">

      <form method="GET" action="/firefighters" style="display:flex;gap:10px;align-items:center;">

        <input
          type="text"
          name="q"
          placeholder="Search by Name, Rank, Station, Roblox ID..."
          value="<%= q || '' %>"
          style="padding:10px 14px;border-radius:8px;border:1px solid #ccc;width:300px;"
        >

        <button type="submit" class="primary-btn">
          Search
        </button>

        <a href="/firefighters" class="primary-btn">
          Clear
        </a>

      </form>

      <a href="/firefighters/new" class="primary-btn">
        Add Firefighter
      </a>

    </div>

  </div>

  <table>

    <thead>

      <tr>
        <th>Name</th>
        <th>Rank</th>
        <th>Station</th>
        <th>Command Level</th>
        <th>Status</th>
        <th>Roblox ID</th>
        <th>Actions</th>
      </tr>

    </thead>

    <tbody>

      <% firefighters.forEach(f => { %>

      <tr>

        <td><%= f.name %></td>

        <td><%= f.rank %></td>

        <td><%= f.station || "-" %></td>

        <td>
          <span class="badge">
            <%= f.command_level || "No Command" %>
          </span>
        </td>

        <td><%= f.status %></td>

        <td><%= f.roblox_id || "-" %></td>

        <td>

          <a href="/firefighters/<%= f.id %>/edit">
            Edit
          </a>

          <form
            method="POST"
            action="/firefighters/<%= f.id %>/delete"
            style="display:inline;"
          >

            <button type="submit">
              Delete
            </button>

          </form>

        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

</section>

<%- include('layout-bottom') %>
